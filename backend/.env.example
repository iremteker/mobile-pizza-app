# MySQL Bağlantı Ayarları
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=pizza_app

# JWT Ayarları
JWT_SECRET=pizzaapp_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d

# Sunucu Ayarları
PORT=3000
NODE_ENV=development

# CORS - Flutter uygulamasının çalıştığı origin
ALLOWED_ORIGINS=http://localhost,http://10.0.2.2
